{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "runnit",
  "version": "0.1.0",
  "identifier": "dev.runnit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm sidecar:build && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "runnit",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "theme": "Dark",
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
